# Image tags
BACKEND_IMAGE=ghcr.io/catchhole-soma/catchhole-backend-java:main
AI_IMAGE=ghcr.io/catchhole-soma/catchhole-backend-ai:main

# Public API domain
API_DOMAIN=api.catchhole.com

# Spring backend
BACKEND_JAVA_OPTS=-Xms256m -Xmx768m
JWT_SECRET=replace-with-at-least-32-byte-secret
INTERNAL_API_KEY=replace-with-internal-api-key
CORS_ALLOWED_ORIGINS=https://catchhole.com,https://www.catchhole.com,https://catch-hole.vercel.app

# PostgreSQL
POSTGRES_DB=catchhole
POSTGRES_USER=catchhole
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# AWS/S3
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=catchhole-dev-037077640960-ap-northeast-2-an
AWS_S3_ENDPOINT_OVERRIDE=
AWS_SQS_QUEUE_URL=

# LLM
LLM_API_KEY=replace-with-llm-api-key
LLM_MODEL=gpt-4.1-mini
OPENAI_RESPONSES_API_URL=https://api.openai.com/v1/responses
